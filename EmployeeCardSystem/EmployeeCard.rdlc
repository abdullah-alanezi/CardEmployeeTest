<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<AutoRefresh>0</AutoRefresh>
	<DataSources>
		<DataSource Name="EmployeeDataSet">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* Local Connection */</ConnectString>
			</ConnectionProperties>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="DS_Employee">
			<Query>
				<DataSourceName>EmployeeDataSet</DataSourceName>
				<CommandText>/* Local Query */</CommandText>
			</Query>
			<Fields>
				<Field Name="Name">
					<DataField>Name</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="EmployeeId">
					<DataField>EmployeeId</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="JobTitle">
					<DataField>JobTitle</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="Photo">
					<DataField>Photo</DataField>
					<rd:TypeName>System.Byte[]</rd:TypeName>
				</Field>
			</Fields>
		</DataSet>
	</DataSets>
	<ReportSections>
		<ReportSection>
			<Body>
				<ReportItems>
					<Rectangle Name="MainCard">
						<ReportItems>

							<Rectangle Name="BlackBackground">
								<Top>0in</Top>
								<Left>0in</Left>
								<Height>1.5in</Height>
								<Width>3in</Width>
								<Style>
									<BackgroundColor>#1A1A1A</BackgroundColor>
									<Border>
										<Style>None</Style>
									</Border>
								</Style>
							</Rectangle>

							<Rectangle Name="RedTriangleTop">
								<Top>0in</Top>
								<Left>2.2in</Left>
								<Height>0.4in</Height>
								<Width>0.8in</Width>
								<Style>
									<BackgroundColor>#E74C3C</BackgroundColor>
									<Border>
										<Style>None</Style>
									</Border>
								</Style>
							</Rectangle>

							<Rectangle Name="PhotoCircleBorder">
								<Top>0.4in</Top>
								<Left>0.75in</Left>
								<Height>1.3in</Height>
								<Width>1.3in</Width>
								<Style>
									<Border>
										<Color>#E74C3C</Color>
										<Style>Solid</Style>
										<Width>3pt</Width>
									</Border>
									<BackgroundColor>White</BackgroundColor>
								</Style>
							</Rectangle>

							<Image Name="EmployeePhoto">
								<Source>Database</Source>
								<Value>=First(Fields!Photo.Value, "DS_Employee")</Value>
								<MIMEType>image/png</MIMEType>
								<Sizing>FitProportional</Sizing>
								<Top>0.45in</Top>
								<Left>0.8in</Left>
								<Height>1.2in</Height>
								<Width>1.2in</Width>
								<Style>
									<Border>
										<Style>None</Style>
									</Border>
								</Style>
							</Image>

							<Textbox Name="txtName">
								<Paragraphs>
									<Paragraph>
										<TextRuns>
											<TextRun>
												<Value>=UCase(First(Fields!Name.Value, "DS_Employee"))</Value>
												<Style>
													<FontFamily>Arial Black</FontFamily>
													<FontSize>14pt</FontSize>
													<FontWeight>Bold</FontWeight>
													<Color>#E74C3C</Color>
												</Style>
											</TextRun>
										</TextRuns>
										<Style>
											<TextAlign>Center</TextAlign>
										</Style>
									</Paragraph>
								</Paragraphs>
								<Top>1.9in</Top>
								<Left>0.1in</Left>
								<Height>0.3in</Height>
								<Width>2.8in</Width>
							</Textbox>

							<Textbox Name="txtJob">
								<Paragraphs>
									<Paragraph>
										<TextRuns>
											<TextRun>
												<Value>=UCase(First(Fields!JobTitle.Value, "DS_Employee"))</Value>
												<Style>
													<FontFamily>Segoe UI</FontFamily>
													<FontSize>11pt</FontSize>
													<FontWeight>Bold</FontWeight>
													<Color>#333333</Color>
												</Style>
											</TextRun>
										</TextRuns>
										<Style>
											<TextAlign>Center</TextAlign>
										</Style>
									</Paragraph>
								</Paragraphs>
								<Top>2.2in</Top>
								<Left>0.1in</Left>
								<Height>0.25in</Height>
								<Width>2.8in</Width>
							</Textbox>

							<Textbox Name="txtID">
								<Paragraphs>
									<Paragraph>
										<TextRuns>
											<TextRun>
												<Value>ID NO : </Value>
												<Style>
													<FontSize>9pt</FontSize>
													<FontWeight>Bold</FontWeight>
												</Style>
											</TextRun>
											<TextRun>
												<Value>=First(Fields!EmployeeId.Value, "DS_Employee")</Value>
												<Style>
													<FontSize>9pt</FontSize>
												</Style>
											</TextRun>
										</TextRuns>
										<Style>
											<TextAlign>Center</TextAlign>
										</Style>
									</Paragraph>
								</Paragraphs>
								<Top>2.5in</Top>
								<Left>0.1in</Left>
								<Height>0.2in</Height>
								<Width>2.8in</Width>
							</Textbox>

							<Rectangle Name="BarcodePlaceholder">
								<Top>2.75in</Top>
								<Left>0.5in</Left>
								<Height>0.4in</Height>
								<Width>2in</Width>
								<Style>
									<BackgroundColor>#F0F0F0</BackgroundColor>
									<Border>
										<Style>Dashed</Style>
									</Border>
								</Style>
							</Rectangle>

							<Rectangle Name="RedTriangleBottom">
								<Top>3.1in</Top>
								<Left>1.8in</Left>
								<Height>0.4in</Height>
								<Width>1.2in</Width>
								<Style>
									<BackgroundColor>#E74C3C</BackgroundColor>
									<Border>
										<Style>None</Style>
									</Border>
								</Style>
							</Rectangle>

						</ReportItems>
						<Height>3.5in</Height>
						<Width>3in</Width>
						<Style>
							<Border>
								<Style>Solid</Style>
								<Color>LightGrey</Color>
							</Border>
						</Style>
					</Rectangle>
				</ReportItems>
				<Height>3.5in</Height>
			</Body>
			<Width>3in</Width>
			<Page>
				<PageHeight>3.5in</PageHeight>
				<PageWidth>3in</PageWidth>
				<Style />
			</Page>
		</ReportSection>
	</ReportSections>
</Report>