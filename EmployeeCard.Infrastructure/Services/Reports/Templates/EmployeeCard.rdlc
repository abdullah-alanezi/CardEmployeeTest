<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="EmployeeDataSet">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>16733e09-2cd1-48fa-a074-1cd2df237b60</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Rectangle Name="MainCard">
            <ReportItems>
              <Rectangle Name="BlackBackground">
                <Height>1.5in</Height>
                <Width>3in</Width>
                <Style>
                  <Border>
                    <Style>None</Style>
                  </Border>
                  <BackgroundColor>#1a1a1a</BackgroundColor>
                </Style>
              </Rectangle>
              <Rectangle Name="RedTriangleTop">
                <Left>2.2in</Left>
                <Height>0.4in</Height>
                <Width>0.8in</Width>
                <ZIndex>1</ZIndex>
                <Style>
                  <Border>
                    <Style>None</Style>
                  </Border>
                  <BackgroundColor>#e74c3c</BackgroundColor>
                </Style>
              </Rectangle>
              <Rectangle Name="PhotoCircleBorder">
                <ReportItems>
                  <Image Name="EmployeePhoto">
                    <Source>Database</Source>
                    <Value>=System.Convert.FromBase64String(Parameters!pPhoto.Value)</Value>
                    <MIMEType>image/jpeg</MIMEType>
                    <Sizing>FitProportional</Sizing>
                    <Top>0.05in</Top>
                    <Left>0.05in</Left>
                    <Height>1.2in</Height>
                    <Width>1.2in</Width>
                    <ToolTip>=Parameters!pPhoto.Value</ToolTip>
                    <Style>
                      <Border>
                        <Style>None</Style>
                      </Border>
                    </Style>
                  </Image>
                </ReportItems>
                <Top>0.4in</Top>
                <Left>0.75in</Left>
                <Height>1.3in</Height>
                <Width>1.3in</Width>
                <ZIndex>2</ZIndex>
                <Style>
                  <Border>
                    <Color>#e74c3c</Color>
                    <Style>Solid</Style>
                    <Width>3pt</Width>
                  </Border>
                  <BackgroundColor>White</BackgroundColor>
                </Style>
              </Rectangle>
              <Textbox Name="txtName">
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>=Parameters!pName.Value</Value>
                        <Style>
                          <FontFamily>Arial Black</FontFamily>
                          <FontSize>14pt</FontSize>
                          <FontWeight>Bold</FontWeight>
                          <Color>#e74c3c</Color>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <Style>
                      <TextAlign>Center</TextAlign>
                    </Style>
                  </Paragraph>
                </Paragraphs>
                <Top>1.9in</Top>
                <Left>0.1in</Left>
                <Height>0.3in</Height>
                <Width>2.8in</Width>
                <ZIndex>3</ZIndex>
                <Style />
              </Textbox>
              <Textbox Name="txtJob">
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>=Parameters!pJobTitle.Value</Value>
                        <Style>
                          <FontFamily>Segoe UI</FontFamily>
                          <FontSize>11pt</FontSize>
                          <FontWeight>Bold</FontWeight>
                          <Color>#333333</Color>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <Style>
                      <TextAlign>Center</TextAlign>
                    </Style>
                  </Paragraph>
                </Paragraphs>
                <Top>2.2in</Top>
                <Left>0.1in</Left>
                <Height>0.25in</Height>
                <Width>2.8in</Width>
                <ZIndex>4</ZIndex>
                <Style />
              </Textbox>
              <Textbox Name="txtID">
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>=Parameters!pEmployeeId.Value</Value>
                        <Style>
                          <FontSize>9pt</FontSize>
                          <FontWeight>Bold</FontWeight>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <Style>
                      <TextAlign>Center</TextAlign>
                    </Style>
                  </Paragraph>
                </Paragraphs>
                <Top>2.5in</Top>
                <Left>0.1in</Left>
                <Height>0.2in</Height>
                <Width>2.8in</Width>
                <ZIndex>5</ZIndex>
                <Style />
              </Textbox>
              <Rectangle Name="BarcodePlaceholder">
                <ReportItems>
                  <Textbox Name="Department">
                    <CanGrow>true</CanGrow>
                    <KeepTogether>true</KeepTogether>
                    <Paragraphs>
                      <Paragraph>
                        <TextRuns>
                          <TextRun>
                            <Value>Department:</Value>
                            <Style>
                              <FontFamily>Segoe UI</FontFamily>
                              <FontWeight>Bold</FontWeight>
                            </Style>
                          </TextRun>
                          <TextRun>
                            <Value>=Parameters!pDepartment.Value</Value>
                            <Style>
                              <FontFamily>Segoe UI</FontFamily>
                              <FontWeight>Bold</FontWeight>
                            </Style>
                          </TextRun>
                        </TextRuns>
                        <Style>
                          <TextAlign>Center</TextAlign>
                        </Style>
                      </Paragraph>
                    </Paragraphs>
                    <rd:DefaultName>Department</rd:DefaultName>
                    <Top>0.1in</Top>
                    <Height>0.25in</Height>
                    <Width>2in</Width>
                    <Style>
                      <Border>
                        <Style>None</Style>
                      </Border>
                      <PaddingLeft>2pt</PaddingLeft>
                      <PaddingRight>2pt</PaddingRight>
                      <PaddingTop>2pt</PaddingTop>
                      <PaddingBottom>2pt</PaddingBottom>
                    </Style>
                  </Textbox>
                </ReportItems>
                <Top>2.75in</Top>
                <Left>0.5in</Left>
                <Height>0.43625in</Height>
                <Width>2in</Width>
                <ZIndex>6</ZIndex>
                <Style>
                  <Border>
                    <Style>Dashed</Style>
                  </Border>
                  <BackgroundColor>#f0f0f0</BackgroundColor>
                </Style>
              </Rectangle>
              <Rectangle Name="RedTriangleBottom">
                <Top>3.1in</Top>
                <Left>1.8in</Left>
                <Height>0.4in</Height>
                <Width>1.2in</Width>
                <ZIndex>7</ZIndex>
                <Style>
                  <Border>
                    <Style>None</Style>
                  </Border>
                  <BackgroundColor>#e74c3c</BackgroundColor>
                </Style>
              </Rectangle>
            </ReportItems>
            <Height>3.5in</Height>
            <Width>3in</Width>
            <Style>
              <Border>
                <Color>LightGrey</Color>
                <Style>Solid</Style>
              </Border>
            </Style>
          </Rectangle>
        </ReportItems>
        <Height>8.89cm</Height>
        <Style />
      </Body>
      <Width>7.62cm</Width>
      <Page>
        <PageHeight>8.89cm</PageHeight>
        <PageWidth>7.62cm</PageWidth>
        <LeftMargin>0cm</LeftMargin>
        <RightMargin>0cm</RightMargin>
        <TopMargin>0cm</TopMargin>
        <BottomMargin>0cm</BottomMargin>
        <ColumnSpacing>1.27cm</ColumnSpacing>
        <Style />
      </Page>
    </ReportSection>
  </ReportSections>
  <ReportParameters>
    <ReportParameter Name="pName">
      <DataType>String</DataType>
      <Prompt>ReportParameter1</Prompt>
    </ReportParameter>
    <ReportParameter Name="pEmployeeId">
      <DataType>String</DataType>
      <Prompt>ReportParameter1</Prompt>
    </ReportParameter>
    <ReportParameter Name="pJobTitle">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>ReportParameter1</Prompt>
    </ReportParameter>
    <ReportParameter Name="pDepartment">
      <DataType>String</DataType>
      <Prompt>ReportParameter1</Prompt>
    </ReportParameter>
    <ReportParameter Name="pPhoto">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>ReportParameter1</Prompt>
    </ReportParameter>
  </ReportParameters>
